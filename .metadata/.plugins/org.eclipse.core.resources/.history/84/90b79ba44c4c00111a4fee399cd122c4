package com.arl.service;

import org.springframework.beans.BeanUtils;

import com.arl.dto.ActorRegistor;
import com.arl.entity.Actor;

public class ActorMngmtService implements IActorMngmtService {

	@Override
	public String registerActor(ActorRegistor actor) {
		// Covert ActorRegisterDto to Actor Entity class object
		
		Actor act=new Actor();
		BeanUtils.copyProperties(actor, act);
		act.setCreatedBy(System.getProperty("user.name"));
	}

}
