package com.arl.rest;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.HttpStatusCode;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.arl.dto.ActorRegistor;
import com.arl.service.IActorMngmtService;

@RestController
@RequestMapping("/actor")
public class ActorOperationsController {

	@Autowired
	private IActorMngmtService service;
	
	@PostMapping("/register")
	public ResponseEntity<String> insertActor(@RequestBody ActorRegistor actor){
		// user Service
		
		try {
			String msg=service.registerActor(actor);
			
			return new ResponseEntity<String>(msg,HttpStatus.CREATED);
		}catch(Exception e) {
			return new ResponseEntity<String>("Problem in insertion", HttpStatus.INTERNAL_SERVER_ERROR);
		}
	}
	
	@PostMapping("/registerAll")
	public ResponseEntity<String> registerAllActors(@RequestBody List<ActorRegistor> list){
		try {
			String msg=service.insertActorsBatch(list);
			return new ResponseEntity<String>(msg,HttpStatusCode.valueOf(200));
		}catch(Exception e) {
			return new ResponseEntity<String>("Problem in insertion", HttpStatus.INTERNAL_SERVER_ERROR);
		}
	}
	
	@GetMapping("/getAllActors")
	public ResponseEntity<?> getAllActors(){
		try {
			Iterable<ActorRegistor> actors=service.getAllActors();
			return new ResponseEntity<Iterable<ActorRegistor>>(actors, HttpStatus.OK);
			
		}catch(Exception e) {
			return new ResponseEntity<String>("No Actors Found", HttpStatus.NOT_FOUND);
		}
	}
	
	@GetMapping("/{id}")
	public ResponseEntity<?> getActorById(@PathVariable Integer id){
		try {
			
		}catch(Exception e) {
			return new ResponseEntity<String>("",HttpStatus.BAD_REQUEST);
		}
	}
}
